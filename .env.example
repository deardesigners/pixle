# Vercel Blob — read/write токен (Vercel Dashboard → Storage → Blob).
BLOB_READ_WRITE_TOKEN=

# Vercel Postgres / Neon — POSTGRES_URL и пр. подставляются автоматически
# при vercel link или после интеграции базы в Storage.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Публичный URL приложения (для абсолютных ссылок в шаринге).
NEXT_PUBLIC_APP_URL=http://localhost:3000
