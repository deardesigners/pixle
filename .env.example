# Meshy AI image-to-3d API. Если пусто — приложение работает в demo-режиме (voxel fallback).
MESHY_API_KEY=

# Vercel Blob — read/write токен из Vercel Dashboard → Storage → Blob.
BLOB_READ_WRITE_TOKEN=

# Vercel Postgres — POSTGRES_URL и пр. подставляются автоматически при vercel link.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Публичный URL приложения (для абсолютных ссылок в шаринге).
NEXT_PUBLIC_APP_URL=http://localhost:3000
